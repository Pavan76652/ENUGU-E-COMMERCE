# ─── App ─────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1
CLIENT_URL=http://localhost:5173
# Log verbosity: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ─── MongoDB ───────────────────────────────────────
# memory = in-memory DB for local dev (no install). Use Atlas URI in production.
# Production (MongoDB Atlas): mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/enugu?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/enugu

# ─── JWT ─────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── bcrypt ──────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Cloudinary (required for future upload module) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=enugu

# ─── Razorpay (required for future payment module) ────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Store Config ────────────────────────────────
FREE_SHIPPING_THRESHOLD=999
CURRENCY=INR

# ─── Security ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGINS=http://localhost:5173
# Production (Netlify): https://your-site.netlify.app (comma-separated for multiple)
# CLIENT_URL above must also be set to the Netlify URL in production.

# ─── Email (optional — logs reset/verify URL in dev if unset) ─
# When SMTP_HOST + SMTP_USER + SMTP_PASS are set, real emails are sent via
# Nodemailer (verification, password reset, order confirmation, back-in-stock).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ENUGU <goudarjun763@gmail.com>

# ─── Super Admin ─────────────────────────────────
# Auto-created on server boot if it does not exist (no manual seed needed).
# Use this account to log in at /admin/login on the deployed site.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
